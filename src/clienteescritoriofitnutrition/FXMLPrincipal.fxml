<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="740.0" prefWidth="1240.0" styleClass="root-app" xmlns="http://javafx.com/fxml/1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="clienteescritoriofitnutrition.FXMLPrincipalController">
    <stylesheets>
        <URL value="@/clienteescritoriofitnutrition/utilidad/estilo.css" />
    </stylesheets>
    <left>
        <VBox prefWidth="230.0" styleClass="menu-lateral">
            <children>
                <HBox alignment="CENTER_LEFT" onMouseDragged="#arrastrarVentana" onMousePressed="#iniciarArrastre" spacing="8.0" styleClass="sidebar-header">
                    <children>
                        <Button mnemonicParsing="false" onAction="#clickCerrarAplicacion" styleClass="btn-semaforo-rojo" />
                        <Button mnemonicParsing="false" onAction="#clickMinimizar" styleClass="btn-semaforo-amarillo" />
                        <Button mnemonicParsing="false" onAction="#clickMaximizar" styleClass="btn-semaforo-verde" />
                        <TextField promptText="Buscar..." styleClass="sidebar-search-box" HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
                <Label styleClass="label-menu" text="PRINCIPAL" />
                <Button fx:id="btnDashboard" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#clickDashboard" styleClass="boton-menu" text="Dashboard" />
                <Button fx:id="btnPacientes" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#clickPacientes" styleClass="boton-menu" text="Pacientes" />
                <Button fx:id="btnMedicos" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#clickMedicos" styleClass="boton-menu" text="Medicos" />
                <Label styleClass="label-menu" text="OPERACION" />
                <Button fx:id="btnCitas" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#clickCitas" styleClass="boton-menu" text="Citas" />
                <Button fx:id="btnConsultas" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#clickConsultas" styleClass="boton-menu" text="Consultas" />
                <Button fx:id="btnDietas" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#clickDietas" styleClass="boton-menu" text="Dietas" />
                <Button fx:id="btnAlimentos" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#clickAlimentos" styleClass="boton-menu" text="Alimentos" />
                <Label styleClass="label-menu" text="CUENTA" />
                <Button fx:id="btnPerfil" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#clickPerfil" styleClass="boton-menu" text="Perfil" />
                <Region VBox.vgrow="ALWAYS" />
                <HBox alignment="CENTER_LEFT" spacing="9.0" styleClass="sidebar-footer">
                    <children>
                        <StackPane styleClass="sidebar-avatar">
                            <children>
                                <Label styleClass="sidebar-avatar-text" text="FN" />
                            </children>
                        </StackPane>
                        <VBox spacing="1.0">
                            <children>
                                <Label fx:id="lbSesion" styleClass="sidebar-username" text="Usuario" />
                                <Label styleClass="sidebar-userrole" text="Sesion activa" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#clickCerrarSesion" styleClass="boton-salir" text="Cerrar sesion" />
            </children>
        </VBox>
    </left>
    <center>
        <BorderPane>
            <top>
                <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="barra-superior">
                    <children>
                        <Label fx:id="lbTitulo" styleClass="label-titulo-principal" text="Dashboard" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label styleClass="status-pill" text="Sistema activo" />
                    </children>
                </HBox>
            </top>
            <center>
                <BorderPane fx:id="bpContenedor" styleClass="contenedor-modulo">
                    <center>
                        <VBox fx:id="vbDashboard" spacing="16.0">
                            <padding>
                                <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                            </padding>
                            <HBox spacing="12.0">
                                <children>
                                    <VBox spacing="3.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                        <children>
                                            <StackPane styleClass="stat-icon">
                                                <children>
                                                    <Label styleClass="stat-icon-text" text="P" />
                                                </children>
                                            </StackPane>
                                            <Label fx:id="lbTotalPacientes" styleClass="label-stat-valor" text="0" />
                                            <Label styleClass="label-stat-nombre" text="Pacientes activos" />
                                            <Label fx:id="lbActivosPacientes" styleClass="label-stat-delta" text="0 activos" />
                                        </children>
                                    </VBox>
                                    <VBox spacing="3.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                        <children>
                                            <StackPane styleClass="stat-icon">
                                                <children>
                                                    <Label styleClass="stat-icon-text" text="M" />
                                                </children>
                                            </StackPane>
                                            <Label fx:id="lbTotalMedicos" styleClass="label-stat-valor" text="0" />
                                            <Label styleClass="label-stat-nombre" text="Medicos" />
                                            <Label fx:id="lbMedicosActivos" styleClass="label-stat-delta" text="0 activos" />
                                        </children>
                                    </VBox>
                                    <VBox spacing="3.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                        <children>
                                            <StackPane styleClass="stat-icon">
                                                <children>
                                                    <Label styleClass="stat-icon-text" text="C" />
                                                </children>
                                            </StackPane>
                                            <Label fx:id="lbCitasHoy" styleClass="label-stat-valor" text="0" />
                                            <Label styleClass="label-stat-nombre" text="Citas hoy" />
                                            <Label fx:id="lbCitasPendientes" styleClass="label-stat-delta" text="0 pendientes" />
                                        </children>
                                    </VBox>
                                    <VBox spacing="3.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                        <children>
                                            <StackPane styleClass="stat-icon">
                                                <children>
                                                    <Label styleClass="stat-icon-text" text="N" />
                                                </children>
                                            </StackPane>
                                            <Label fx:id="lbConsultasTotal" styleClass="label-stat-valor" text="0" />
                                            <Label styleClass="label-stat-nombre" text="Consultas totales" />
                                            <Label fx:id="lbConsultasHoy" styleClass="label-stat-delta" text="0 hoy" />
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>
                            <HBox spacing="14.0" VBox.vgrow="ALWAYS">
                                <children>
                                    <VBox styleClass="panel" HBox.hgrow="ALWAYS">
                                        <children>
                                            <HBox alignment="CENTER_LEFT" styleClass="panel-header">
                                                <children>
                                                    <Label styleClass="label-panel" text="Pacientes recientes" />
                                                    <Region HBox.hgrow="ALWAYS" />
                                                    <Label styleClass="label-stat-delta" text="Ver todos" />
                                                </children>
                                            </HBox>
                                            <VBox fx:id="vbPacientesRecientes" spacing="12.0" styleClass="panel-body" />
                                        </children>
                                    </VBox>
                                    <VBox styleClass="panel" HBox.hgrow="ALWAYS">
                                        <children>
                                            <HBox alignment="CENTER_LEFT" styleClass="panel-header">
                                                <children>
                                                    <Label styleClass="label-panel" text="Citas del dia" />
                                                    <Region HBox.hgrow="ALWAYS" />
                                                    <Label fx:id="lbFechaCitas" styleClass="label-subtitulo" text="" />
                                                </children>
                                            </HBox>
                                            <VBox fx:id="vbCitasHoy" spacing="10.0" styleClass="panel-body" />
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>
                        </VBox>
                    </center>
                </BorderPane>
            </center>
            <bottom>
                <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="statusbar">
                    <children>
                        <Label styleClass="label-status" text="Sistema activo" />
                        <Label styleClass="label-status" text="localhost:8080" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lbFechaFooter" styleClass="label-status" text="" />
                    </children>
                </HBox>
            </bottom>
        </BorderPane>
    </center>
</BorderPane>
