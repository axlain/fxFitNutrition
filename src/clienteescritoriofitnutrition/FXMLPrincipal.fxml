                <Button fx:id="btnConsultas" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#clickConsultas" styleClass="boton-menu" text="Consultas" />
                <Button fx:id="btnDietas" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#clickDietas" styleClass="boton-menu" text="Dietas" />
                <Button fx:id="btnAlimentos" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#clickAlimentos" styleClass="boton-menu" text="Alimentos" />
                <Region VBox.vgrow="ALWAYS" />
                <HBox alignment="CENTER_LEFT" spacing="9.0" styleClass="sidebar-footer">
                    <children>
                        <StackPane styleClass="sidebar-avatar">
                            <children>
                                <Label styleClass="sidebar-avatar-text" text="FN" />
                            </children>
                        </StackPane>
                        <VBox spacing="1.0">
