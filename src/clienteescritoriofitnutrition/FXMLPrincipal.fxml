<BorderPane prefHeight="720.0" prefWidth="1180.0" styleClass="root-app" xmlns="http://javafx.com/fxml/1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="clienteescritoriofitnutrition.FXMLPrincipalController">
    <stylesheets>
        <URL value="@/clienteescritoriofitnutrition/utilidad/estilo.css" />
    </stylesheets>
    <left>
        <VBox prefWidth="200.0" styleClass="menu-lateral">
