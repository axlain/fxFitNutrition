                        <Button mnemonicParsing="false" onAction="#clickCerrarAplicacion" styleClass="btn-semaforo-rojo" />
                        <Button mnemonicParsing="false" onAction="#clickMinimizar" styleClass="btn-semaforo-amarillo" />
                        <Button mnemonicParsing="false" onAction="#clickMaximizar" styleClass="btn-semaforo-verde" />
