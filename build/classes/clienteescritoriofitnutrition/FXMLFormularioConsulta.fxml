<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>

<AnchorPane id="AnchorPane" prefHeight="480.0" prefWidth="600.0" styleClass="fondo-formulario"
            xmlns="http://javafx.com/fxml/1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="clienteescritoriofitnutrition.FXMLFormularioConsultaController">

    <stylesheets>
        <URL value="@/clienteescritoriofitnutrition/utilidad/estilo.css" />
    </stylesheets>

    <children>
        <Label layoutX="32.0" layoutY="25.0" styleClass="titulo-formulario" text="Información de la Consulta" />

        <GridPane hgap="16.0" layoutX="32.0" layoutY="73.0" prefHeight="330.0" prefWidth="536.0" vgap="16.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>

            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>

            <children>
                <AnchorPane>
                    <children>
                        <Label styleClass="etiqueta-campo" text="Paciente (*)" />
                        <ComboBox fx:id="cbPaciente" layoutY="22.0" prefHeight="35.0" prefWidth="260.0"
                                  promptText="Seleccionar paciente" styleClass="combo-box"
                                  AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />
                    </children>
                </AnchorPane>

                <AnchorPane GridPane.columnIndex="1">
                    <children>
                        <Label styleClass="etiqueta-campo" text="Médico (*)" />
                        <ComboBox fx:id="cbMedico" layoutY="22.0" prefHeight="35.0" prefWidth="260.0"
                                  promptText="Seleccionar médico" styleClass="combo-box"
                                  AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />
                    </children>
                </AnchorPane>

                <AnchorPane GridPane.rowIndex="1">
                    <children>
                        <Label styleClass="etiqueta-campo" text="Cita (*)" />

                        <HBox layoutY="22.0" prefHeight="35.0" prefWidth="260.0" spacing="8.0"
                              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
                            <children>
                                <ComboBox fx:id="cbCita" prefHeight="35.0" prefWidth="205.0"
                                          promptText="Seleccionar cita" styleClass="combo-box" />

                                <Button fx:id="btnCrearCita"
                                        mnemonicParsing="false"
                                        onAction="#clickCrearCita"
                                        prefHeight="35.0"
                                        prefWidth="47.0"
                                        styleClass="boton-secundario"
                                        text="+" />
                            </children>
                        </HBox>
                    </children>
                </AnchorPane>

                <AnchorPane GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <children>
                        <Label styleClass="etiqueta-campo" text="Dieta Asignada" />
                        <ComboBox fx:id="cbDieta" layoutY="22.0" prefHeight="35.0" prefWidth="260.0"
                                  promptText="Seleccionar dieta" styleClass="combo-box"
                                  AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />
                    </children>
                </AnchorPane>

                <AnchorPane GridPane.rowIndex="2">
                    <children>
                        <Label styleClass="etiqueta-campo" text="Peso (kg) (*)" />
                        <TextField fx:id="tfPeso" layoutY="22.0" prefHeight="35.0" prefWidth="260.0"
                                   promptText="Ej: 75.5" styleClass="campo-texto"
                                   AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />
                    </children>
                </AnchorPane>

                <AnchorPane GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <children>
                        <Label styleClass="etiqueta-campo" text="Estatura (m) (*)" />
                        <TextField fx:id="tfEstatura" layoutY="22.0" prefHeight="35.0" prefWidth="260.0"
                                   promptText="Ej: 1.75" styleClass="campo-texto"
                                   AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />
                    </children>
                </AnchorPane>

                <AnchorPane GridPane.rowIndex="3">
                    <children>
                        <Label styleClass="etiqueta-campo" text="Talla (*)" />
                        <TextField fx:id="tfTalla" layoutY="22.0" prefHeight="35.0" prefWidth="260.0"
                                   promptText="Ej: M, L" styleClass="campo-texto"
                                   AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />
                    </children>
                </AnchorPane>

                <AnchorPane GridPane.columnIndex="1" GridPane.rowIndex="3">
                    <children>
                        <Label styleClass="etiqueta-campo" text="IMC (Calculado)" />
                        <TextField fx:id="tfImc" disable="true" editable="false" layoutY="22.0" prefHeight="35.0" prefWidth="260.0"
                                   styleClass="campo-texto"
                                   AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />
                    </children>
                </AnchorPane>

                <AnchorPane GridPane.columnSpan="2" GridPane.rowIndex="4">
                    <children>
                        <Label styleClass="etiqueta-campo" text="Observaciones" />
                        <TextField fx:id="tfObservaciones" layoutY="22.0" prefHeight="35.0" prefWidth="536.0"
                                   styleClass="campo-texto"
                                   AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />
                    </children>
                </AnchorPane>
            </children>
        </GridPane>

        <HBox alignment="CENTER_RIGHT" layoutX="32.0" layoutY="420.0" prefHeight="35.0" prefWidth="536.0" spacing="12.0">
            <children>
                <Button mnemonicParsing="false" onAction="#clickCalcularIMC" styleClass="boton-secundario" text="Calcular IMC" />
                <Button mnemonicParsing="false" onAction="#clickCancelar" styleClass="boton-secundario" text="Cancelar" />
                <Button mnemonicParsing="false" onAction="#clickGuardar" styleClass="boton-primario" text="Guardar" />
            </children>
        </HBox>
    </children>
</AnchorPane>